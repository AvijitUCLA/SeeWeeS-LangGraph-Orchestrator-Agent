# ── Email / SMTP ──────────────────────────────────────────────
# Option A: Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
REPORT_EMAIL_TO=recipient@example.com

# Option B: Zoho (comment out Option A above and uncomment below)
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=465
# SMTP_USER=your_email@zohomail.com
# SMTP_PASSWORD=your_zoho_app_password_here
# REPORT_EMAIL_TO=recipient@example.com

# ── LangSmith Tracing (optional) ──────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your_langsmith_api_key_here
LANGCHAIN_PROJECT=MSBA_AI_Agents_Demo
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Weather Fallback (used if waypoint parsing fails) ─────────
WEATHER_LAT=40.7282
WEATHER_LON=-74.0776
WEATHER_TZ=America/New_York
